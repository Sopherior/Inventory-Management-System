              <language>java</language>
              <body>try {
         //Username and Password saved as configurable properties to allow changes without recompilation.
         prop = new Properties();
         prop.loadFromXML(new FileInputStream(&quot;C:\\Users\\nutty\\OneDrive\\Desktop\\CapstoneProject\\Capstone Project\\src\\com\\inventory\\Database\\DBCredentials.xml&quot;));
