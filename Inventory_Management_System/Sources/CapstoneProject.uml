            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTAUM2R1Ee6-PPx48m8iYA" name="getFullName" specification="_DPtIlWR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTAUNGR1Ee6-PPx48m8iYA" name="userDTO" type="_DN2HYGR1Ee6-PPx48m8iYA"/>
              <ownedParameter xmi:id="_DTAUNWR1Ee6-PPx48m8iYA" name="username">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT * FROM users WHERE username='&quot; +username+ &quot;' LIMIT 1&quot;;
         resultSet = statement.executeQuery(query);
         String fullName = null;
         if(resultSet.next()) fullName = resultSet.getString(2);
         userDTO.setFullName(fullName);
     } catch (SQLException ex) {
         ex.printStackTrace();
     }
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTAUNmR1Ee6-PPx48m8iYA" name="getUserLogsDAO" specification="_DNDdMGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTAUN2R1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT users.name,userlogs.username,in_time,out_time,location FROM userlogs&quot; +
                 &quot; INNER JOIN users on userlogs.username=users.username&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTAUOGR1Ee6-PPx48m8iYA" name="addUserLogin" specification="_DPtvoWR1Ee6-PPx48m8iYA">
