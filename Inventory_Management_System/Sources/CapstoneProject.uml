     codeText.setText(&quot;&quot;);
     nameText.setText(&quot;&quot;);
     locationText.setText(&quot;&quot;);
     phoneText.setText(&quot;&quot;);
     searchText.setText(&quot;&quot;);
     repNameText.setText(&quot;&quot;);
     repPhoneText.setText(&quot;&quot;);
     accountText.setText(&quot;&quot;);
 </body>
            </ownedBehavior>
