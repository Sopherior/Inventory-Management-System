            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS9Q42R1Ee6-PPx48m8iYA" name="addSupplierDAO" specification="_DPhiYGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS9Q5GR1Ee6-PPx48m8iYA" name="supplierDTO" type="_DNoE8GR1Ee6-PPx48m8iYA"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT * FROM suppliers WHERE suppliername='&quot;
                 +supplierDTO.getFullName()
                 + &quot;' AND location='&quot;
                 +supplierDTO.getLocation()
                 + &quot;' AND phone='&quot;
                 +supplierDTO.getPhone()
                 + &quot;' AND repname='&quot;
                 +supplierDTO.getRepName()
                 + &quot;' AND repphone='&quot;
                 +supplierDTO.getRepPhone()
                 + &quot;' AND account='&quot;
                 +supplierDTO.getAccount()
                 + &quot;'&quot;;
         resultSet = statement.executeQuery(query);
         if (resultSet.next())
             JOptionPane.showMessageDialog(null, &quot;This supplier already exists.&quot;);
         else
             addFunction(supplierDTO);
     } catch (SQLException e) {
         e.printStackTrace();
     }
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS9Q5WR1Ee6-PPx48m8iYA" name="addFunction" specification="_DPhiYmR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS9Q5mR1Ee6-PPx48m8iYA" name="supplierDTO" type="_DNoE8GR1Ee6-PPx48m8iYA"/>
              <language>java</language>
              <body>try {
         String query = &quot;INSERT INTO suppliers VALUES(null,?,?,?,?,?,?,?)&quot;;
         prepStatement = conn.prepareStatement(query);
         prepStatement.setString(1, supplierDTO.getSuppCode());
         prepStatement.setString(2, supplierDTO.getFullName());
         prepStatement.setString(3, supplierDTO.getLocation());
         prepStatement.setString(4, supplierDTO.getPhone());
         prepStatement.setString(5, supplierDTO.getRepName());
         prepStatement.setString(6, supplierDTO.getRepPhone());
         prepStatement.setString(7, supplierDTO.getAccount());
         prepStatement.executeUpdate();
         JOptionPane.showMessageDialog(null, &quot;New supplier has been added successfully.&quot;);
     } catch (SQLException e) {
         e.printStackTrace();
     }
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS9Q52R1Ee6-PPx48m8iYA" name="editSupplierDAO" specification="_DPhiZGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS9Q6GR1Ee6-PPx48m8iYA" name="supplierDTO" type="_DNoE8GR1Ee6-PPx48m8iYA"/>
              <language>java</language>
              <body>try {
         String query = &quot;UPDATE suppliers SET suppliername=?,location=?,phone=?,repname=?,repphone=?,account=? WHERE suppliercode=?&quot;;
         prepStatement = conn.prepareStatement(query);
         prepStatement.setString(1, supplierDTO.getFullName());
         prepStatement.setString(2, supplierDTO.getLocation());
         prepStatement.setString(3, supplierDTO.getPhone());
         prepStatement.setString(4, supplierDTO.getSuppCode());
         prepStatement.setString(5, supplierDTO.getRepName());
         prepStatement.setString(6, supplierDTO.getRepPhone());
         prepStatement.setString(7, supplierDTO.getAccount());
         prepStatement.executeUpdate();
         JOptionPane.showMessageDialog(null, &quot;Supplier details have been updated.&quot;);
     } catch (SQLException e) {
         e.printStackTrace();
     }
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS9Q6WR1Ee6-PPx48m8iYA" name="deleteSupplierDAO" specification="_DMzlkGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS9Q6mR1Ee6-PPx48m8iYA" name="suppCode">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <language>java</language>
              <body>try {
         String query = &quot;DELETE FROM suppliers WHERE suppliercode='&quot; +suppCode+ &quot;'&quot;;
         statement.executeUpdate(query);
         JOptionPane.showMessageDialog(null, &quot;Supplier has been removed.&quot;);
     } catch (SQLException e) {
         e.printStackTrace();
     }
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS938GR1Ee6-PPx48m8iYA" name="getQueryResult" specification="_DMzlkmR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS938WR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT suppliercode, suppliername, location, phone, repname, repphone, account FROM suppliers&quot;;
         resultSet = statement.executeQuery(query);
     } catch (Exception e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS938mR1Ee6-PPx48m8iYA" name="getSearchResult" specification="_DM0MoGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS9382R1Ee6-PPx48m8iYA" name="searchText">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_DS939GR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT suppliercode, suppliername, location, phone, repname, repphone, account FROM suppliers &quot; +
                 &quot;WHERE suppliercode LIKE '%&quot;+searchText+&quot;%' OR location LIKE '%&quot;+searchText+&quot;%' &quot; +
                 &quot;OR fullname LIKE '%&quot;+searchText+&quot;%' OR mobile LIKE '%&quot;+searchText+&quot;%' OR repname LIKE '%&quot;+searchText+&quot;%' OR repphone LIKE '%&quot;+searchText+&quot;%' OR account LIKE '%&quot;+searchText+&quot;%'&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS939WR1Ee6-PPx48m8iYA" name="setComboItems" specification="_DQzUwWR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS939mR1Ee6-PPx48m8iYA" name="resultSet" type="_DQxfkWR1Ee6-PPx48m8iYA"/>
              <ownedParameter xmi:id="_DS9392R1Ee6-PPx48m8iYA" type="_DQyGo2R1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>Vector&lt;String> suppNames = new Vector&lt;>();
     while (resultSet.next()){
         suppNames.add(resultSet.getString(&quot;suppliername&quot;));
     }
     return new DefaultComboBoxModel&lt;>(suppNames);
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS93-GR1Ee6-PPx48m8iYA" name="buildTableModel" specification="_DQz70WR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DS93-WR1Ee6-PPx48m8iYA" name="resultSet" type="_DQxfkWR1Ee6-PPx48m8iYA"/>
              <ownedParameter xmi:id="_DS93-mR1Ee6-PPx48m8iYA" type="_DPfGIGR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>ResultSetMetaData metaData = resultSet.getMetaData();
     Vector&lt;String> columnNames = new Vector&lt;String>();
     int colCount = metaData.getColumnCount();

     for (int col=1; col &lt;= colCount; col++){
         columnNames.add(metaData.getColumnName(col).toUpperCase(Locale.ROOT));
     }

     Vector&lt;Vector&lt;Object>> data = new Vector&lt;Vector&lt;Object>>();
     while (resultSet.next()) {
         Vector&lt;Object> vector = new Vector&lt;Object>();
         for (int col=1; col&lt;=colCount; col++) {
             vector.add(resultSet.getObject(col));
         }
         data.add(vector);
     }
     return new DefaultTableModel(data, columnNames);
 </body>
            </ownedBehavior>
