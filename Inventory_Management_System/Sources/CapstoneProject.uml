              <language>java</language>
              <body>try {
         String query = &quot;SELECT productcode,productname,costprice,totalprice,supplier,products.quantity FROM products ORDER BY pid&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException throwables) {
         throwables.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTZ81WR1Ee6-PPx48m8iYA" name="getPurchaseInfo" specification="_DOTaYGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTZ81mR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT PurchaseID,purchaseinfo.ProductCode,ProductName,purchaseinfo.costprice,purchaseinfo.totalcost,purchaseinfo.supplier,purchaseinfo.Quantity &quot; +
                 &quot;FROM purchaseinfo INNER JOIN products &quot; +
                 &quot;ON products.productcode=purchaseinfo.productcode ORDER BY purchaseid;&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException throwables) {
         throwables.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
