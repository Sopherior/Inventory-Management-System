              <body>//GEN-FIRST:event_clearButtonActionPerformed
     codeText.setText(&quot;&quot;);
     nameText.setText(&quot;&quot;);
     jDateChooser1.setDate(null);
     quantityText.setText(&quot;&quot;);
     costText.setText(&quot;&quot;);
     supplierText.setText(&quot;&quot;);
     searchText.setText(&quot;&quot;);
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTNvlGR1Ee6-PPx48m8iYA" name="searchTextKeyReleased" specification="_DQCfxmR1Ee6-PPx48m8iYA">
