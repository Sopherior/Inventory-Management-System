            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTaj4mR1Ee6-PPx48m8iYA" name="getSalesInfo" specification="_DOTaYmR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTaj42R1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT salesid,salesinfo.productcode,salesinfo.productname, salesinfo.quantity,users.name AS Sold_by FROM salesinfo INNER JOIN products ON salesinfo.productcode=products.productcode INNER JOIN users ON salesinfo.soldby=users.username;&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException throwables) {
         throwables.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTaj5GR1Ee6-PPx48m8iYA" name="getProductSearch" specification="_DOUBcGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTaj5WR1Ee6-PPx48m8iYA" name="text">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_DTaj5mR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT productcode,productname,costprice,totalprice,supplier,quantity FROM products &quot; +
                 &quot;WHERE productcode LIKE '%&quot;+text+&quot;%' OR productname LIKE '%&quot;+text+&quot;%' OR supplier LIKE '%&quot;+text+&quot;%'&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
