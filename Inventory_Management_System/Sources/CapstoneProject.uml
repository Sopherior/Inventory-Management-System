            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DS8CwGR1Ee6-PPx48m8iYA" name="printInventory" specification="_DMUdYWR1Ee6-PPx48m8iYA">
              <language>java</language>
              <body>conn = new ConnectionFactory().getConn();&#xD;
     String sql=&quot;SELECT * FROM products&quot;;&#xD;
     try{&#xD;
         System.getProperty(&quot;user.dir&quot;);&#xD;
         System.out.println(&quot;Working Directory = &quot; + System.getProperty(&quot;user.dir&quot;));&#xD;
&#xD;
         JasperDesign jasperDesign = JRXmlLoader.load(&quot;C:\\Users\\nutty\\OneDrive\\Desktop\\New folder (2)\\Capstone Project\\build\\classes\\com\\inventory\\PDF\\inventory_report.jrxml&quot;);&#xD;
         JRDesignQuery updateQuery=new JRDesignQuery();&#xD;
         updateQuery.setText(sql);&#xD;
         jasperDesign.setQuery(updateQuery);&#xD;
         JasperReport jasperReport= JasperCompileManager.compileReport(jasperDesign);&#xD;
         JasperPrint jasperPrint= JasperFillManager.fillReport(jasperReport,null,conn);&#xD;
         JasperViewer.viewReport(jasperPrint ,false);&#xD;
     }catch (Exception err){&#xD;
         err.printStackTrace();&#xD;
     }&#xD;
 </body>
            </ownedBehavior>
