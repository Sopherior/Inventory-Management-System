              </ownedParameter>
              <ownedParameter xmi:id="_DTaj6WR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT productcode,productname,costprice,supplier FROM products &quot; +
                 &quot;WHERE productcode='&quot; +text+ &quot;' LIMIT 1&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTbK8GR1Ee6-PPx48m8iYA" name="getSalesSearch" specification="_DOUogGR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTbK8WR1Ee6-PPx48m8iYA" name="text">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_DTbK8mR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT salesid,salesinfo.productcode,salesinfo.productname,\n&quot; +
                 &quot;                    salesinfo.quantity,users.name AS Sold_by\n&quot; +
                 &quot;                    FROM salesinfo INNER JOIN products\n&quot; +
                 &quot;                    ON salesinfo.productcode=products.productcode\n&quot; +
                 &quot;                    INNER JOIN users\n&quot; +
                 &quot;                    ON salesinfo.soldby=users.username\n&quot; +
                 &quot;WHERE salesinfo.productcode LIKE '%&quot;+text+&quot;%' OR salesinfo.productname LIKE '%&quot;+text+&quot;%' &quot; +
                 &quot;OR users.name LIKE '%&quot;+text+&quot;%' ORDER BY salesid;&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
            <ownedBehavior xmi:type="uml:OpaqueBehavior" xmi:id="_DTbK82R1Ee6-PPx48m8iYA" name="getPurchaseSearch" specification="_DOUogmR1Ee6-PPx48m8iYA">
              <ownedParameter xmi:id="_DTbK9GR1Ee6-PPx48m8iYA" name="text">
                <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
              </ownedParameter>
              <ownedParameter xmi:id="_DTbK9WR1Ee6-PPx48m8iYA" type="_DQxfkWR1Ee6-PPx48m8iYA" direction="return"/>
              <language>java</language>
              <body>try {
         String query = &quot;SELECT PurchaseID,purchaseinfo.productcode,products.productname,purchaseinfo.costprice,totalcost,purchaseinfo.supplier,quantity &quot; +
                 &quot;FROM purchaseinfo INNER JOIN products ON purchaseinfo.productcode=products.productcode &quot; +
                 &quot;INNER JOIN suppliers ON purchaseinfo.suppliercode=suppliers.suppliercode&quot; +
                 &quot;WHERE PurchaseID LIKE '%&quot;+text+&quot;%' OR productcode LIKE '%&quot;+text+&quot;%' OR productname LIKE '%&quot;+text+&quot;%' OR suppliers.suppliername LIKE '%&quot;+text+&quot;%' OR purchaseinfo.suppliercode LIKE '%&quot;+text+&quot;%' +OR date LIKE '%&quot;+text+&quot;%' ORDER BY purchaseid&quot;;
         resultSet = statement.executeQuery(query);
     } catch (SQLException e) {
         e.printStackTrace();
     }
     return resultSet;
 </body>
            </ownedBehavior>
